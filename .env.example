# ─────────────────────────────────────────────────────────────────
#  Per-machine overrides for the VoxCPM2 TTS service.
#
#  EVERY field in config.yaml has a VOXTTS_* override here. Copy this to
#  `.env` (gitignored) and uncomment what you need; loaded at startup
#  (python-dotenv). A real shell env var of the same name always wins.
#  config.yaml stays SHARED across machines — only this .env differs.
#
#    cp .env.example .env   &&   edit
#
#  Notes:
#   - Booleans: 1/0, true/false, yes/no, on/off.
#   - "_or_none" values: leave blank to disable (e.g. VOXTTS_API_KEY=).
#   - VOXTTS_VOICE_PROMPT / _SEPARATOR keep exact whitespace (a space is a
#     space) — quote in shells if needed.
# ─────────────────────────────────────────────────────────────────

# ══ Quick machine presets ════════════════════════════════════════
# ── 🟩 GB10 (DGX Spark / Blackwell, GPU server) ──
# VOXTTS_HF_HOME=/home/dgx1/repo/tts-server/hf_cache
# VOXTTS_CUDNN=0
# VOXTTS_OPTIMIZE=0
# VOXTTS_MATMUL_PRECISION=highest
# ── 🪟 Windows RTX 3060 (local dev) ──
# VOXTTS_HF_HOME=D:/Weil/Desktop/AI/tts/hf_cache
# VOXTTS_OPTIMIZE=0
# VOXTTS_MATMUL_PRECISION=high

# ══ server ═══════════════════════════════════════════════════════
# VOXTTS_HOST=0.0.0.0
# VOXTTS_PORT=9824
# VOXTTS_API_KEY=                       # blank = no auth
# VOXTTS_CORS_ORIGINS=*                 # comma-separated, e.g. https://a,https://b

# ══ model ════════════════════════════════════════════════════════
# VOXTTS_MODEL=openbmb/VoxCPM2
# VOXTTS_HF_HOME=/path/to/hf_cache
# VOXTTS_DEVICE=cuda                    # cuda / cuda:0 / cpu / blank=auto
# VOXTTS_LOAD_DENOISER=0
# VOXTTS_OPTIMIZE=1                     # torch.compile (0 on GB10/Windows)
# VOXTTS_CUDNN=1                        # 0 = bypass cuDNN
# VOXTTS_MATMUL_PRECISION=high          # high|highest|medium|blank

# ══ voice ════════════════════════════════════════════════════════
# VOXTTS_VOICE_PROMPT=(A gentle, soft and sweet young girl's voice)
# VOXTTS_VOICE_PROMPT_SEPARATOR=         # "" = no space between (prompt) and text
# VOXTTS_REFERENCE_WAV=voice/ariel.wav   # voice cloning (most consistent)
# VOXTTS_REFERENCE_TEXT=transcript of the reference clip

# ══ generation ═══════════════════════════════════════════════════
# VOXTTS_SEED=20240601                  # blank = random each call
# VOXTTS_CFG_VALUE=2.0                  # higher = obey the prompt more
# VOXTTS_INFERENCE_TIMESTEPS=10         # higher = better/slower
# VOXTTS_NORMALIZE=1
# VOXTTS_DENOISE=0                      # needs VOXTTS_LOAD_DENOISER=1
# VOXTTS_RETRY_BADCASE=1                # 0 = strict/reproducible (no auto re-roll)
# VOXTTS_RETRY_BADCASE_MAX_TIMES=3
# VOXTTS_RETRY_BADCASE_RATIO_THRESHOLD=6.0
# VOXTTS_MAX_CHARS=400                  # blank = no cap
# VOXTTS_EMBED_META=0                   # 1 = embed params into each wav's metadata
