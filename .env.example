# ─────────────────────────────────────────────────────────────────
#  Per-machine overrides for the VoxCPM2 TTS service.
#
#  Copy this to `.env` (gitignored) and uncomment the block for your
#  machine. These are loaded at startup (python-dotenv); a real shell
#  env var of the same name always wins. config.yaml stays SHARED and
#  unchanged across machines — only this .env differs.
#
#    cp .env.example .env   &&   edit
# ─────────────────────────────────────────────────────────────────

# ── 🟩 GB10 (DGX Spark / Blackwell, the GPU server) ────────────────
# A system cuDNN in /lib shadows the pip wheel and crashes convs, so we
# bypass cuDNN (the diffusion LM, not convs, is the bottleneck anyway).
# VOXTTS_HF_HOME=/home/dgx1/repo/tts-server/hf_cache
# VOXTTS_CUDNN=0
# VOXTTS_OPTIMIZE=0
# VOXTTS_MATMUL_PRECISION=high
#
#   (Want to KEEP cuDNN for speed instead of VOXTTS_CUDNN=0? That needs
#    LD_LIBRARY_PATH set *before* launch — it can't come from this .env.
#    See the README "Troubleshooting" section / the systemd unit.)

# ── 🪟 Windows RTX 3060 (local dev) ────────────────────────────────
# cuDNN works; triton isn't installed so torch.compile no-ops on its own.
# VOXTTS_HF_HOME=D:/Weil/Desktop/AI/tts/hf_cache
# VOXTTS_OPTIMIZE=0
# VOXTTS_MATMUL_PRECISION=high

# ── Other available overrides ──────────────────────────────────────
# VOXTTS_HOST=0.0.0.0
# VOXTTS_PORT=9824
# VOXTTS_API_KEY=change-me
# VOXTTS_MODEL=openbmb/VoxCPM2
# VOXTTS_DEVICE=cuda
# VOXTTS_SEED=20240601
# VOXTTS_CUDNN=1            # 1=use cuDNN, 0=bypass
